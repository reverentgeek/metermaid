{
	"name": "metermaid-site",
	"version": "1.0.0",
	"description": "Landing page for MeterMaid, a cross-platform LUFS / loudness meter.",
	"scripts": {
		"build:css": "tailwindcss -i src/css/styles.css -o _site/css/styles.css --minify",
		"build:11ty": "eleventy",
		"build": "pnpm build:11ty && pnpm build:css",
		"dev:css": "tailwindcss -i src/css/styles.css -o _site/css/styles.css --watch",
		"dev:11ty": "eleventy --serve",
		"dev": "node scripts/dev.mjs",
		"test": "pnpm build && playwright test",
		"test:install": "playwright install chromium"
	},
	"keywords": [
		"metermaid",
		"lufs",
		"loudness",
		"audio",
		"eleventy"
	],
	"author": "David Neal <david@reverentgeek.com> (https://reverentgeek.com/)",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"devDependencies": {
		"@11ty/eleventy": "^3.1.6",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/cli": "^4.3.1",
		"eleventy-plugin-edgejs": "^1.1.14",
		"markdown-it": "^14.2.0",
		"tailwindcss": "^4.3.1"
	}
}
